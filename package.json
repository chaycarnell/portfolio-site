{
  "name": "portfolio-site",
  "version": "1.0.0",
  "description": "portfolio website built with react using Contenful headless CMS deployed to GitHub Pages",
  "license": "ISC",
  "author": {
    "name": "Chay Carnell",
    "email": "chaycarnell@gmail.com",
    "url": "https://chaycarnell.com"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && vite build --emptyOutDir",
    "check:outdated": "yarn outdated || true",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "generate:contentful-types": "cf-content-types-generator -s REPLACE_ME  -t REPLACE_ME -o ./src/types",
    "lint": "tsc --noEmit && eslint . --ext ts,js,tsx,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "yarn run lint --fix",
    "prepare": "husky",
    "prettier:write": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "preview": "vite preview",
    "sort:package": "npx sort-package-json",
    "test": "true",
    "test:ci": "true"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "15.22.11",
    "@contentful/rich-text-types": "16.8.5",
    "axios": "1.7.7",
    "contentful": "11.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-ga4": "2.1.0",
    "react-helmet": "^6.1.0",
    "react-loading-skeleton": "3.5.0",
    "react-responsive-carousel": "3.2.23",
    "react-router-dom": "6.27.0",
    "styled-components": "6.1.13"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-helmet": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cf-content-types-generator": "^2.15.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.6",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-tsconfig-paths": "^5.0.1"
  }
}
