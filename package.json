{
  "name": "portfolio-site",
  "version": "1.0.0",
  "description": "portfolio website built with react using Contenful headless CMS deployed to GitHub Pages",
  "license": "ISC",
  "author": {
    "name": "Chay Carnell",
    "email": "chaycarnell@gmail.com",
    "url": "https://chaycarnell.com"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && vite build --emptyOutDir",
    "check:audit": "yarn npm audit --severity high",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "generate:contentful-types": "cf-content-types-generator -s REPLACE_ME  -t REPLACE_ME -o ./src/types",
    "lint": "tsc --noEmit && eslint . --ext ts,js,tsx,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "yarn run lint --fix",
    "prepare": "husky",
    "prettier:write": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "preview": "vite preview",
    "sort": "npx sort-package-json",
    "test": "true",
    "test:ci": "true",
    "upgrade": "yarn upgrade-interactive"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "16.0.0",
    "@contentful/rich-text-types": "17.0.0",
    "axios": "1.7.9",
    "contentful": "11.3.1",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-ga4": "2.1.0",
    "react-loading-skeleton": "3.5.0",
    "react-responsive-carousel": "3.2.23",
    "react-router-dom": "7.0.2",
    "styled-components": "6.1.13"
  },
  "devDependencies": {
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@types/react-helmet": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitejs/plugin-react": "^4.3.4",
    "cf-content-types-generator": "^2.15.5",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "packageManager": "yarn@4.5.3",
  "engines": {
    "node": ">=21"
  }
}
