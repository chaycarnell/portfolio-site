{
  "name": "portfolio-site",
  "version": "1.0.0",
  "description": "portfolio website built with react using Contentful headless CMS deployed to GitHub Pages",
  "license": "ISC",
  "author": {
    "name": "Chay Carnell",
    "email": "chaycarnell@gmail.com",
    "url": "https://chaycarnell.com"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && vite build --emptyOutDir",
    "check:audit": "yarn npm audit --severity moderate",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "lint": "tsc --noEmit && eslint . --ext ts,js,tsx,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "yarn run lint --fix",
    "prepare": "husky",
    "prettier:write": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "preview": "vite preview",
    "sort": "npx sort-package-json",
    "test": "true",
    "test:ci": "true",
    "upgrade": "yarn upgrade-interactive"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "16.2.1",
    "@contentful/rich-text-types": "17.2.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-ga4": "3.0.1",
    "react-responsive-carousel": "3.2.23",
    "react-router-dom": "7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-helmet": "^6.1.11",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  },
  "packageManager": "yarn@4.9.3",
  "engines": {
    "node": ">=24.6.0"
  }
}
