{
  "name": "portfolio-site",
  "version": "1.0.0",
  "description": "portfolio website built with react using contenful headless CMS deployed to GitHub Pages",
  "license": "ISC",
  "author": {
    "name": "Chay Carnell",
    "email": "chaycarnell@gmail.com",
    "url": "https://chaycarnell.com"
  },
  "type": "module",
  "scripts": {
    "build": "tsc && vite build --emptyOutDir",
    "check:audit": "yarn audit --level high",
    "check:outdated": "yarn outdated || true",
    "check:types": "tsc --noEmit",
    "dev": "vite",
    "lint": "eslint . --ext ts,js,tsx,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "yarn run lint --fix",
    "prepare": "husky",
    "prettier:write": "prettier --write \"**/*.{js,ts,tsx,json}\"",
    "preview": "vite preview",
    "sort:package": "npx sort-package-json",
    "test": "true",
    "test:ci": "true"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@contentful/rich-text-react-renderer": "15.22.1",
    "@contentful/rich-text-types": "16.6.1",
    "axios": "1.7.2",
    "contentful": "10.12.7",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-ga4": "2.1.0",
    "react-loading-skeleton": "3.4.0",
    "react-responsive-carousel": "3.2.23",
    "react-router-dom": "6.24.1",
    "styled-components": "6.1.11"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.0.11",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3"
  }
}
